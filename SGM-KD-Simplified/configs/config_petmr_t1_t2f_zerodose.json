{
    "model": {
        "type": "image_v1",
        "input_channels": 1,
        "unet_cond_dim": 6,
        "patch_size": 1,
        "input_size": [256, 256],
        "mapping_out": 256,
        "depths": [2, 2, 2],
        "channels": [64, 128, 256],
        "self_attn_depths": [false, false, true],
        "has_variance": false,
        "loss_config": "karras",
        "loss_weighting": "soft-min-snr",
        "dropout_rate": 0.05,
        "augment_wrapper": false,
        "sigma_data": 0.5,
        "sigma_min": 1e-2,
        "sigma_max": 10,
        "sigma_sample_density": {
            "type": "cosine-interpolated"
        }
    },
    "dataset": {
        "type": "petmr",
        "cond_key": "mri",
        "image_key": "pet"
    },
    "optimizer": {
        "type": "adamw",
        "lr": 5e-4,
        "betas": [0.9, 0.95],
        "eps": 1e-8,
        "weight_decay": 1e-3
    },
    "lr_sched": {
        "type": "constant",
        "warmup": 0.0
    },
    "ema_sched": {
        "type": "inverse",
        "power": 0.75,
        "max_value": 0.9999
    }
}
